# ─────────────────────────────────────────────────────────────────
# Lead Capture Workflow — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000

# ── Google Sheets ─────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/ and create a project.
# 2. Enable the "Google Sheets API" for that project.
# 3. Create a Service Account (IAM & Admin → Service Accounts).
# 4. Generate a JSON key for the service account and download it.
# 5. Open the JSON key file and copy the relevant fields below.
# 6. In Google Sheets, share your spreadsheet with the service
#    account email (e.g. my-sa@project.iam.gserviceaccount.com)
#    giving it "Editor" access.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Copy the private_key from your JSON key file.
# Keep the quotes and the literal \n characters.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR KEY HERE\n-----END RSA PRIVATE KEY-----\n"

# The ID of your Google Sheet — found in the URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# The exact name of the sheet tab to write to (default: Sheet1)
GOOGLE_SHEET_NAME=Leads

# ── OpenAI ────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# If left blank the app uses a template acknowledgment instead.
OPENAI_API_KEY=sk-...
